Public Sub Init( _
            ByVal a_Recordset As Object)
    Const ERR_SOURCE As String = "Init()"
    If TypeName(a_Recordset) <> "Recordset" Then _
        Call RaiseError( _
            etInvalidRecordset, _
            ERR_SOURCE, _
            "ˆّگ”‚ح`ADODB.Recordset`ƒIƒuƒWƒFƒNƒg‚إ‚ب‚¯‚ê‚خ‚ب‚ç‚ب‚¢پB")
    
    ' CursorType‚ًadOpenStatic”›‚è‚ة‚·‚é
    '   - RecordCountƒvƒچƒpƒeƒBپAMoveFirst()ƒپƒ\ƒbƒh—ک—p‚ج‚½‚ك
    If a_Recordset.CursorType <> adOpenStatic Then _
        Call RaiseError( _
            etInvalidCursorType, _
            ERR_SOURCE, _
            "Recordset‚جCursorType‚حadOpenStatic(=3)‚إ‚ب‚¯‚ê‚خ‚ب‚ç‚ب‚¢پB")
    
    Set m_Recordset = a_Recordset
End Sub

Public Sub Export( _
            ByVal a_FilePath As String, _
   Optional ByVal a_ErrorDesc As String = "")
    Const ERR_SOURCE As String = "Export()"
    ' m_Recordset‚ھNothing -> —لٹOƒXƒچپ[
    If m_Recordset Is Nothing Or TypeName(m_Recordset) <> "Recordset" Then _
        Call RaiseError( _
            etInvalidRecordset, _
            ERR_SOURCE, _
            "RecordsetƒIƒuƒWƒFƒNƒg‚ھƒZƒbƒg‚³‚ê‚ؤ‚¢‚ب‚¢پB")
    
    Dim json As String
    If a_ErrorDesc <> "" Then
        json = "{""columns"": [""error""], ""rows"": " & _
               "[[""" & a_ErrorDesc & """]]}"
    Else
        json = BuildJSON()
    End If
    ' JSONƒtƒ@ƒCƒ‹‚ًƒGƒNƒXƒ|پ[ƒg
    Dim strm As Object
    Set strm = CreateObject("ADODB.Stream")
    With strm
        .Type = adTypeText
        .Charset = "utf-8"
        Call .Open
    End With
    Call strm.WriteText(json)
    Call strm.SaveToFile(a_FilePath, adSaveCreateOverWrite)
    Call strm.Close
    Set strm = Nothing
End Sub

