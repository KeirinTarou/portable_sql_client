Attribute VB_Name = "FakeDataFactory"
Attribute VB_GlobalNameSpace = False
Attribute VB_Creatable = False
Attribute VB_PredeclaredId = False
Attribute VB_Exposed = False
Option Explicit

Private Const ERR_BASE_NUMBER As Long = vbObjectError + 5000

Private Enum ErrTypeEnum
    errInvalidArg = 1
    errNotEvenNumberOfArgs = 2
    errInvalidKey = 3
    errInvalidValue = 4
    errDuplicateKey = 5
    errEmptyKey = 6
    errNullKey = 7
    errBlankKey = 8
    errTooLongKey = 9
    errHasInvalidChar = 10
    errKeyMustBeScalar = 11
End Enum

Private m_Rows As Variant

Private Sub Class_Initialize()
    m_Rows = Array()
End Sub

' 1‘g‚جkey-valueƒyƒA‚ًٹi”[‚µ‚½ƒfƒBƒNƒVƒ‡ƒiƒٹ‚ً•ش‚·
Public Function GenScalar( _
            ByVal a_Key As String, _
            ByVal a_Value As Variant) As Object
    Const ERR_SOURCE As String = "GenScalar()"
    
    Dim paramArr(0 To 1) As Variant
    paramArr(0) = a_Key
    ' 2‚آ–ع‚جˆّگ”‚حƒIƒuƒWƒFƒNƒg‚ج‰آ”\گ«‚ھ‚ ‚é
    If IsObject(a_Value) Then
        Set paramArr(1) = a_Value
    Else
        paramArr(1) = a_Value
    End If
    
    On Error Resume Next
    Dim dic As Object
    Set dic = BuildDictFromArray(paramArr)
    Dim errNum As Long, errDesc As String
    errNum = Err.Number
    errDesc = Err.Description
    On Error GoTo 0
    If errNum <> 0 Then
        Call Err.Raise(errNum, ERR_SOURCE, errDesc)
    End If
    
    Set GenScalar = dic
End Function

' •،گ”‘g‚جkey-valueƒyƒA‚ًٹi”[‚µ‚½ƒfƒBƒNƒVƒ‡ƒiƒٹ‚ً•ش‚·
Public Function GenRow( _
            ParamArray a_Params()) As Object
    Const ERR_SOURCE As String = "GenRow()"
    
    On Error Resume Next
    Dim dic As Object
    Set dic = BuildDictFromArray(a_Params)
    Dim errNum As Long, errDesc As String
    errNum = Err.Number
    errDesc = Err.Description
    On Error GoTo 0
    If errNum <> 0 Then
        Call Err.Raise(errNum, ERR_SOURCE, errDesc)
    End If
    
    Set GenRow = dic
End Function

' گV‚½‚ة1چs•ھ‚جƒfƒBƒNƒVƒ‡ƒiƒٹ‚ًچى‚ء‚ؤ”z—ٌ‚ة’ا‰ء -> ’ا‰ءŒم‚ج”z—ٌ‚ً•ش‚·
Public Function AddRow( _
            ParamArray a_Params()) As Variant
    Const ERR_SOURCE As String = "AddRow()"
    
    On Error Resume Next
    Dim dic As Object
    Set dic = BuildDictFromArray(a_Params)
    Dim errNum As Long, errDesc As String
    errNum = Err.Number
    errDesc = Err.Description
    On Error GoTo 0
    If errNum <> 0 Then
        Call Err.Raise(errNum, ERR_SOURCE, errDesc)
    End If
    
    Dim lb As Long, ub As Long
    lb = LBound(m_Rows)
    ub = UBound(m_Rows)
    ReDim Preserve m_Rows(lb To ub + 1)
    Set m_Rows(ub + 1) = dic
    AddRow = m_Rows
End Function

Public Sub Clear()
    m_Rows = Array()
End Sub

